# ── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=shieldnet
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── JWT ──────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_key
JWT_EXPIRES_IN=24h

# ── ML Service ───────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
